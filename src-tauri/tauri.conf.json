{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sinograph Dictionary",
  "version": "0.2.0",
  "identifier": "com.yoong.sinograph-dictionary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sinograph Dictionary",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/canonical_v3.sqlite",
      "resources/scer_v4.onnx",
      "resources/scer_anchor_db_v20.npy",
      "resources/class_index.json"
    ]
  }
}
